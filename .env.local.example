# ============================================================
# Required — Supabase (database, auth, storage)
# Get these from: Supabase Dashboard > Project Settings > API
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Public base URL of the deployed app (used for password-reset and share links).
# Local: http://localhost:3000   |   Railway: https://your-app.up.railway.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Service-role key (SECRET — server-side only, never exposed to the browser).
# Required for public preview links: the /api/preview route uses it to verify
# passwords and count views without leaking the password hash. Same page as the
# anon key: Supabase Dashboard > Project Settings > API > service_role.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================================
# Optional
# ============================================================
# Transactional email (member-invite notifications) — https://resend.com/api-keys
# Without this, invites still work; they just don't send an email.
RESEND_API_KEY=
# Verified sender. Until you verify a domain in Resend, use onboarding@resend.dev.
EMAIL_FROM=Boarded <onboarding@resend.dev>

# Contract AI generation ("Generate with AI" in Contracts) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Payment integrations (not required to run)
NEXT_PUBLIC_RAZORPAY_KEY=
NEXT_PUBLIC_STRIPE_KEY=
